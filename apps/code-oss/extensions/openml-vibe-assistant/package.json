{
  "name": "openml-vibe-assistant",
  "displayName": "OpenML Vibe Assistant",
  "description": "Asistente integrado de OpenML Code con soporte para LLM locales y proveedores remotos.",
  "publisher": "openml",
  "license": "MIT",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/marlonleandro/open-ml-code"
  },
  "homepage": "https://github.com/marlonleandro/open-ml-code",
  "bugs": {
    "url": "https://github.com/marlonleandro/open-ml-code/issues"
  },
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:openmlAssistant.openChat",
    "onCommand:openmlAssistant.editWithPreview",
    "onCommand:openmlAssistant.generatePlan",
    "onCommand:openmlAssistant.selectProvider",
    "onCommand:openmlAssistant.openSettings",
    "onCommand:openmlAssistant.manageApiKeys",
    "onCommand:openmlAssistant.showMcpServers",
    "onView:openmlAssistant.chatView",
    "onCommand:openmlAssistant.rebuildIndex",
    "onCommand:openmlAssistant.rememberProjectNote",
    "onCommand:openmlAssistant.addWorkspaceRule"
  ],
  "main": "./out/extension",
  "capabilities": {
    "virtualWorkspaces": true,
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "configured-servers",
        "label": "OpenML Assistant MCP Servers"
      }
    ],
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "openml-assistant",
          "title": "OpenML Assistant",
          "icon": "./media/openml-assistant.svg"
        }
      ]
    },
    "views": {
      "openml-assistant": [
        {
          "type": "webview",
          "id": "openmlAssistant.chatView",
          "name": "OpenML Assistant",
          "contextualTitle": "OpenML Assistant",
          "icon": "./media/openml-assistant.svg",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "openmlAssistant.openChat",
        "title": "Open Chat",
        "category": "OpenML Assistant"
      },
      {
        "command": "openmlAssistant.editWithPreview",
        "title": "Edit With Preview",
        "category": "OpenML Assistant"
      },
      {
        "command": "openmlAssistant.generatePlan",
        "title": "Generate Plan",
        "category": "OpenML Assistant"
      },
      {
        "command": "openmlAssistant.selectProvider",
        "title": "Select Provider",
        "category": "OpenML Assistant"
      },
      {
        "command": "openmlAssistant.openSettings",
        "title": "Open Settings",
        "category": "OpenML Assistant"
      },
      {
        "command": "openmlAssistant.manageApiKeys",
        "title": "Manage API Keys",
        "category": "OpenML Assistant"
      },
      {
        "command": "openmlAssistant.showMcpServers",
        "title": "Show MCP Servers",
        "category": "OpenML Assistant"
      },
      {
        "title": "Rebuild Semantic Index",
        "command": "openmlAssistant.rebuildIndex",
        "category": "OpenML Assistant"
      },
      {
        "title": "Remember Project Note",
        "command": "openmlAssistant.rememberProjectNote",
        "category": "OpenML Assistant"
      },
      {
        "title": "Add Workspace Rule",
        "command": "openmlAssistant.addWorkspaceRule",
        "category": "OpenML Assistant"
      }
    ],
    "configuration": {
      "title": "OpenML Assistant",
      "properties": {
        "openmlAssistant.provider": {
          "type": "string",
          "enum": [
            "ollama",
            "lmstudio",
            "openai",
            "gemini",
            "anthropic",
            "openrouter",
            "azurefoundry"
          ],
          "default": "ollama",
          "markdownDescription": "Proveedor activo del asistente. `ollama` y `lmstudio` son las opciones recomendadas para trabajo con LLM locales.",
          "scope": "application"
        },
        "openmlAssistant.systemPrompt": {
          "type": "string",
          "default": "You are OpenML Code Assistant. Produce practical implementation plans with concrete files, steps, risks, and tests. When working in edit mode, prefer responses that can be previewed and applied safely inside the IDE.",
          "markdownDescription": "Prompt de sistema base usado por el asistente.",
          "scope": "application"
        },
        "openmlAssistant.requestTimeoutMs": {
          "type": "number",
          "default": 300000,
          "minimum": 1000,
          "markdownDescription": "Timeout en milisegundos para llamadas al proveedor del modelo.",
          "scope": "application"
        },
        "openmlAssistant.semanticSearch.provider": {
          "type": "string",
          "enum": [
            "local",
            "openai",
            "azurefoundry"
          ],
          "default": "local",
          "markdownDescription": "Semantic retrieval provider used for workspace indexing. `local` keeps the current offline vector fallback. `openai` and `azurefoundry` enable real external embeddings with automatic fallback to local vectors if they fail.",
          "scope": "application"
        },
        "openmlAssistant.semanticSearch.openaiModel": {
          "type": "string",
          "default": "text-embedding-3-small",
          "markdownDescription": "Embedding model used when `openmlAssistant.semanticSearch.provider` is set to `openai`.",
          "scope": "application"
        },
        "openmlAssistant.semanticSearch.azureFoundryDeployment": {
          "type": "string",
          "default": "",
          "markdownDescription": "Embedding deployment or model name used when `openmlAssistant.semanticSearch.provider` is set to `azurefoundry`.",
          "scope": "application"
        },
        "openmlAssistant.mcp.servers": {
          "type": "array",
          "default": [],
          "markdownDescription": "List of MCP servers published by OpenML Assistant to the editor. This first phase supports `stdio` and `http` definitions and lets the built-in MCP infrastructure discover them.",
          "items": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string",
                "description": "Human-readable server name."
              },
              "transport": {
                "type": "string",
                "enum": [
                  "stdio",
                  "http"
                ],
                "description": "Transport type for the MCP server."
              },
              "enabled": {
                "type": "boolean",
                "default": true,
                "description": "Whether this MCP server should be published."
              },
              "command": {
                "type": "string",
                "description": "Executable used for stdio MCP servers."
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Arguments for stdio MCP servers."
              },
              "cwd": {
                "type": "string",
                "description": "Optional working directory for stdio MCP servers."
              },
              "env": {
                "type": "object",
                "description": "Optional environment overrides for stdio MCP servers."
              },
              "url": {
                "type": "string",
                "description": "Endpoint URL for HTTP MCP servers."
              },
              "headers": {
                "type": "object",
                "description": "Optional headers for HTTP MCP servers."
              },
              "version": {
                "type": "string",
                "description": "Optional version identifier used by the editor to detect tool refreshes."
              }
            }
          },
          "scope": "application"
        },
        "openmlAssistant.ollama.baseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:11434",
          "markdownDescription": "Base URL de Ollama.",
          "scope": "application"
        },
        "openmlAssistant.ollama.model": {
          "type": "string",
          "default": "llama3.2",
          "markdownDescription": "Modelo de Ollama a utilizar.",
          "scope": "application"
        },
        "openmlAssistant.ollama.maxOutputTokens": {
          "type": "number",
          "default": 28000,
          "minimum": 512,
          "markdownDescription": "Maximo de tokens de salida solicitados a Ollama para respuestas largas y propuestas editables multiarchivo.",
          "scope": "application"
        },
        "openmlAssistant.lmStudio.baseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:1234/v1",
          "markdownDescription": "Base URL compatible con OpenAI de LM Studio.",
          "scope": "application"
        },
        "openmlAssistant.lmStudio.model": {
          "type": "string",
          "default": "local-model",
          "markdownDescription": "Modelo configurado en LM Studio.",
          "scope": "application"
        },
        "openmlAssistant.lmStudio.maxOutputTokens": {
          "type": "number",
          "default": 28000,
          "minimum": 512,
          "markdownDescription": "Maximo de tokens de salida solicitados a LM Studio para respuestas largas y propuestas editables multiarchivo.",
          "scope": "application"
        },
        "openmlAssistant.openai.baseUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "markdownDescription": "Base URL de OpenAI.",
          "scope": "application"
        },
        "openmlAssistant.openai.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "API key de OpenAI.",
          "scope": "application"
        },
        "openmlAssistant.openai.model": {
          "type": "string",
          "default": "",
          "markdownDescription": "Modelo a utilizar con OpenAI.",
          "scope": "application"
        },
        "openmlAssistant.openai.maxOutputTokens": {
          "type": "number",
          "default": 28000,
          "minimum": 512,
          "markdownDescription": "Maximo de tokens de salida solicitados a OpenAI para respuestas largas y propuestas editables multiarchivo.",
          "scope": "application"
        },
        "openmlAssistant.gemini.baseUrl": {
          "type": "string",
          "default": "https://generativelanguage.googleapis.com/v1beta",
          "markdownDescription": "Base URL de Gemini API.",
          "scope": "application"
        },
        "openmlAssistant.gemini.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "API key de Google AI Studio / Gemini.",
          "scope": "application"
        },
        "openmlAssistant.gemini.model": {
          "type": "string",
          "default": "",
          "markdownDescription": "Modelo a utilizar con Gemini.",
          "scope": "application"
        },
        "openmlAssistant.anthropic.baseUrl": {
          "type": "string",
          "default": "https://api.anthropic.com/v1",
          "markdownDescription": "Base URL de Anthropic.",
          "scope": "application"
        },
        "openmlAssistant.anthropic.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "API key de Anthropic.",
          "scope": "application"
        },
        "openmlAssistant.anthropic.model": {
          "type": "string",
          "default": "",
          "markdownDescription": "Modelo a utilizar con Anthropic.",
          "scope": "application"
        },
        "openmlAssistant.openRouter.baseUrl": {
          "type": "string",
          "default": "https://openrouter.ai/api/v1",
          "markdownDescription": "Base URL de OpenRouter.",
          "scope": "application"
        },
        "openmlAssistant.openRouter.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "API key de OpenRouter.",
          "scope": "application"
        },
        "openmlAssistant.openRouter.model": {
          "type": "string",
          "default": "",
          "markdownDescription": "Modelo a utilizar con OpenRouter.",
          "scope": "application"
        },
        "openmlAssistant.openRouter.appName": {
          "type": "string",
          "default": "OpenML Code",
          "markdownDescription": "Titulo enviado a OpenRouter para identificar la app.",
          "scope": "application"
        },
        "openmlAssistant.openRouter.maxOutputTokens": {
          "type": "number",
          "default": 28000,
          "minimum": 512,
          "markdownDescription": "Maximo de tokens de salida solicitados a OpenRouter para respuestas largas y propuestas editables multiarchivo.",
          "scope": "application"
        },
        "openmlAssistant.openRouter.siteUrl": {
          "type": "string",
          "default": "",
          "markdownDescription": "URL opcional enviada a OpenRouter.",
          "scope": "application"
        },
        "openmlAssistant.historyTokenBudget": {
          "type": "number",
          "default": 4000,
          "minimum": 1000,
          "markdownDescription": "Presupuesto aproximado de tokens para el historial persistente por proyecto guardado en la carpeta `.openml`.",
          "scope": "window"
        },
        "openmlAssistant.gemini.maxOutputTokens": {
          "type": "number",
          "default": 28000,
          "minimum": 512,
          "markdownDescription": "Maximo de tokens de salida solicitados a Gemini para respuestas largas, incluyendo propuestas editables multiarchivo. Si el proveedor sigue truncando, aumenta este valor manualmente.",
          "scope": "application"
        },
        "openmlAssistant.anthropic.maxOutputTokens": {
          "type": "number",
          "default": 28000,
          "minimum": 512,
          "markdownDescription": "Maximo de tokens de salida solicitados a Anthropic para respuestas largas, incluyendo propuestas editables multiarchivo.",
          "scope": "application"
        },
        "openmlAssistant.azureFoundry.host": {
          "type": "string",
          "default": "https://YOUR-RESOURCE.cognitiveservices.azure.com",
          "markdownDescription": "Host o endpoint de Azure AI Foundry / Azure OpenAI. Acepta tanto la base `https://tu-recurso.cognitiveservices.azure.com` como el endpoint completo `https://tu-recurso.cognitiveservices.azure.com/openai/responses?api-version=2025-04-01-preview`.",
          "scope": "application"
        },
        "openmlAssistant.azureFoundry.apiVersion": {
          "type": "string",
          "default": "2025-04-01-preview",
          "markdownDescription": "Version de API para Azure Foundry Responses API.",
          "scope": "application"
        },
        "openmlAssistant.azureFoundry.deployment": {
          "type": "string",
          "default": "",
          "markdownDescription": "Nombre del deployment o modelo configurado en Azure Foundry que se enviara en el campo `model`.",
          "scope": "application"
        },
        "openmlAssistant.azureFoundry.authMode": {
          "type": "string",
          "enum": [
            "bearer",
            "api-key"
          ],
          "default": "bearer",
          "markdownDescription": "Modo de autenticacion para Azure Foundry. Usa `bearer` para tokens como en tu ejemplo o `api-key` si tu recurso lo requiere.",
          "scope": "application"
        },
        "openmlAssistant.azureFoundry.maxOutputTokens": {
          "type": "number",
          "default": 28000,
          "minimum": 256,
          "markdownDescription": "Maximo de tokens de salida solicitados a Azure Foundry para respuestas largas y propuestas editables multiarchivo.",
          "scope": "application"
        },
        "openmlAssistant.azureFoundry.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "Credencial de Azure Foundry. Se migra a SecretStorage.",
          "scope": "application"
        }
      }
    }
  },
  "scripts": {
    "compile": "gulp compile-extension:openml-vibe-assistant",
    "watch": "gulp watch-extension:openml-vibe-assistant"
  }
}
