{
  "name": "vibe-assistant",
  "displayName": "Vibe Assistant",
  "description": "MVP inicial del asistente para tu IDE propio.",
  "version": "0.1.0",
  "publisher": "custom-ide",
  "private": true,
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:vibeAssistant.openPlanner",
    "onCommand:vibeAssistant.planFromSelection"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vibeAssistant.openPlanner",
        "title": "Vibe Assistant: Open Planner"
      },
      {
        "command": "vibeAssistant.planFromSelection",
        "title": "Vibe Assistant: Create Plan From Selection"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p .",
    "typecheck": "tsc -p . --noEmit"
  },
  "dependencies": {
    "@custom-ide/agent-core": "workspace:*",
    "@custom-ide/shared-types": "workspace:*"
  },
  "devDependencies": {
    "@types/vscode": "^1.100.0",
    "typescript": "^5.8.2"
  }
}

